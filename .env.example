# ─── Server ───────────────────────────────────────────────
SERVER_PORT=8080

# ─── Database ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=flowlist
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# ─── JWT ──────────────────────────────────────────────────
# Secret must be at least 32 characters (256 bits) for HS256
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars!!
# How many days a token stays valid
JWT_EXPIRATION_DAYS=30

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,https://your-app.netlify.app
